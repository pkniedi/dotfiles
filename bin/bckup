#!/usr/bin/env zsh

# Creates compressed archive files of dirs specified in DIRS_TO_BACKUP array.
#
# Runs as a CRON job according to:
# 0 15 * * * zsh ~/bin/bckup
# 10 15 */3 * * zsh ~/bin/bckup r
# that is, makes  backups and cleans tmp file every 3 days at 15:10.

# Dirs
BACKUPS=$HOME/backups
THIS_BACKUP_DIR=$BACKUPS/week-$(date +%W)
BACKUPS_TMP=$BACKUPS/.bck
mkdir -p $THIS_BACKUP_DIR $BACKUPS_TMP

BACKUP_LOG=$BACKUPS/.backup-log
touch $BACKUP_LOG

# For crontab
if [[ $1 -eq 'r' ]];then
    rm $BACKUPS_TMP/* && echo "$(date +'%a %b %m %H:%M:%S'): Cleaned \".bck\" dir" >> $BACKUP_LOG
fi

DIRS_TO_BACKUP=(
$HOME/notes
$HOME/dotfiles
$HOME/projects
)

printf "$(date +'%a %b %m %H:%M:%S'): starting backup...\n"  | tee -a $BACKUP_LOG
for dir in "$DIRS_TO_BACKUP[@]";do
    name=$(echo $dir | rev | cut -d'/' -f1 | rev)
    cd $dir
    cd ..
    if [[ -f $THIS_BACKUP_DIR/$name.tar.xz ]];then
        mv $THIS_BACKUP_DIR/$name.tar.xz $BACKUPS_TMP
        printf "$(date +'%a %b %m %H:%M:%S'): moving \"$name.tar.xz\" to .tmp"
    fi

    # use xz with best compression
    printf "$(date +'%a %b %m %H:%M:%S'): Start backup of \"$dir\"\n"  | tee -a $BACKUP_LOG
    XZ_OPT=-9 tar -cJf $THIS_BACKUP_DIR/$name.tar.xz $name
    printf "$(date +'%a %b %m %H:%M:%S'): backup of \"$dir\" done\n"  | tee -a $BACKUP_LOG
done

printf "$(date +'%a %b %m %H:%M:%S'): finished backup. Total size: $(du -sh $THIS_BACKUP_DIR | cut -d '/' -f1)\n"  | tee -a $BACKUP_LOG
